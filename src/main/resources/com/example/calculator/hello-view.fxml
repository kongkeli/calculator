<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.calculator.HelloController">

    <VBox spacing="10" alignment="CENTER" style="-fx-padding: 25px; -fx-background-color: radial-gradient(center 50% 50%, radius 75%, #002200, #000000);">

        <HBox alignment="CENTER">
            <Region HBox.hgrow="ALWAYS" />
            <Label text="C A L C U L A T O R  v3.0" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #00FF41; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.3, 0, 0);"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label text="> History" underline="true" onMouseClicked="#openHistory" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #00FF41; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.3, 0, 0);"/>
        </HBox>

        <TextField fx:id="display" editable="false" onKeyPressed="#handleKeyboard"
                   style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 30px; -fx-font-weight: bold; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-padding: 10px; -fx-effect: dropshadow(gaussian, #00FF41, 10, 0.3, 0, 0);"/>

        <HBox spacing="10" alignment="CENTER">
            <Button text="C" onAction="#handleClear" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #FF3333; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="DEL" onAction="#handleDelete" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 18px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #FFFFFF; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #FFFFFF, 8, 0.4, 0, 0);"/>
            <Button text="(" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text=")" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER">
            <Button text="[" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="]" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="\%" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="/" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER">
            <Button text="7" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="8" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="9" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="*" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER">
            <Button text="4" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="5" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="6" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="-" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER">
            <Button text="1" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="2" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="3" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="+" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER">
            <Button text="0" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="." onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="^" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
            <Button text="√" onAction="#handleInput" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 22px; -fx-font-weight: bold; -fx-pref-width: 60px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.2, 0, 0);"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER">
            <Button text="=" onAction="#handleEqual" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 28px; -fx-font-weight: bold; -fx-pref-width: 270px; -fx-pref-height: 60px; -fx-background-color: #001100; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-border-width: 2px; -fx-effect: dropshadow(gaussian, #00FF41, 8, 0.3, 0, 0);"/>
        </HBox>

        <VBox spacing="5" alignment="CENTER" style="-fx-padding: 10px 0 0 0;">
            <Label text="> Help_" underline="true" onMouseClicked="#openHelp" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #00FF41; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, #00FF41, 5, 0.3, 0, 0);"/>
            <Label text="© Made by Konstantinos Gkelis &amp; Konstantinos Kiousis" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px; -fx-text-fill: #00FF41; -fx-opacity: 0.8;"/>
        </VBox>
    </VBox>

    <VBox fx:id="helpPopup" visible="false" alignment="CENTER" style="-fx-background-color: rgba(0, 0, 0, 0.85);">
        <VBox alignment="CENTER" spacing="15" maxWidth="340" maxHeight="220" style="-fx-background-color: #020a02; -fx-border-color: #39FF14; -fx-border-width: 2px; -fx-padding: 20px; -fx-effect: dropshadow(gaussian, #39FF14, 15, 0.3, 0, 0);">
            <Label text="SUPPORT TEAM" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #39FF14;"/>
            <Label text="Feel free to contact our team.&#10;We will be happy to answer you!" textAlignment="CENTER" wrapText="true" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 12px; -fx-text-fill: #39FF14;"/>
            <Label text="• kgelis21@gmail.com&#10;• konstantinosqcs@gmail.com" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11px; -fx-text-fill: #39FF14;"/>
            <Button text="[ OK ]" onAction="#closeHelp" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-color: transparent; -fx-text-fill: #39FF14; -fx-cursor: hand;"/>
        </VBox>
    </VBox>

    <VBox fx:id="secretPopup" visible="false" alignment="CENTER" style="-fx-background-color: rgba(0, 0, 0, 0.85);">
        <VBox alignment="CENTER" spacing="15" maxWidth="300" maxHeight="150" style="-fx-background-color: #020a02; -fx-border-color: #39FF14; -fx-border-width: 2px; -fx-padding: 20px; -fx-effect: dropshadow(gaussian, #39FF14, 15, 0.3, 0, 0);">
            <Label text="[ SYSTEM UNLOCKED ]" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #39FF14;"/>
            <Label text="Welcome, Creators." style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 14px; -fx-text-fill: #39FF14;"/>
            <Button text="[ OK ]" onAction="#closeSecret" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-color: transparent; -fx-text-fill: #39FF14; -fx-cursor: hand;"/>
        </VBox>
    </VBox>

    <VBox fx:id="historyPopup" visible="false" alignment="CENTER" style="-fx-background-color: rgba(0, 0, 0, 0.85);">
        <VBox alignment="TOP_CENTER" spacing="15" maxWidth="340" maxHeight="300" style="-fx-background-color: #020a02; -fx-border-color: #39FF14; -fx-border-width: 2px; -fx-padding: 20px; -fx-effect: dropshadow(gaussian, #39FF14, 15, 0.3, 0, 0);">
            <Label text="[ CALCULATION LOG ]" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #39FF14;"/>
            <VBox alignment="TOP_LEFT" spacing="5" VBox.vgrow="ALWAYS" style="-fx-padding: 10px 0;">
                <Label fx:id="historyLabel" text="No history yet_" wrapText="true" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 14px; -fx-text-fill: #39FF14;"/>
            </VBox>
            <HBox alignment="CENTER" spacing="30">
                <Button text="[ CLEAR ]" onAction="#clearHistory" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-color: transparent; -fx-text-fill: #FF3333; -fx-cursor: hand;"/>
                <Button text="[ CLOSE ]" onAction="#closeHistory" style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-color: transparent; -fx-text-fill: #39FF14; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </VBox>

</StackPane>